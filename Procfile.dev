# Procfile.dev — root process file for overmind
# Launch with: bin/dev

api:    cd apps/ehr-api    && bin/rails server -p 3000
css:    cd apps/ehr-api    && bin/rails dartsass:watch
portal: bin/wait-for http://localhost:3000/api/up && cd apps/ehr-portal && bin/dev
guard:  cd apps/ehr-api    && bin/guard
