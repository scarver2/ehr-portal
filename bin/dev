#!/usr/bin/env bash
# bin/dev
# Starts the full development environment:
#   - Containerized Postgres on port 5433  (via Docker Compose)
#   - pgAdmin 4 on port 5050               (via Docker Compose)
#   - Rails API on port 3000               (hot-reloading)
#   - Dart Sass watcher
#   - Next.js portal on port 3001          (hot-reloading)

source "$(dirname "$0")/_lib.sh"

banner

# Start Docker services. --wait blocks until Postgres healthcheck passes;
# pgadmin4 has no healthcheck so it starts in parallel without delaying boot.
echo "==> Starting Docker services (Postgres + pgAdmin4)..."
docker compose up -d --wait

# Export DB connection vars for Docker Compose (compose.yml maps host 5433 → container 5432).
# These are inherited by all overmind child processes; apps read them via database.yml.
export DB_HOST=localhost DB_PORT=5433 DB_USER=postgres DB_PASSWORD=postgres

# TODO: Remove db:reset once the schema and seeds are stable enough that a
#       fresh database is no longer needed on every dev boot.
echo "==> Resetting database..."
cd "$ROOT_DIR/apps/ehr-api" && bin/rails db:drop db:create db:migrate db:seed

echo "==> Starting dev processes..."
exec overmind start -f "$ROOT_DIR/Procfile.dev"
