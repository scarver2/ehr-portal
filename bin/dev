#!/usr/bin/env bash
# bin/dev
# Starts the full development environment:
#   - Containerized Postgres (via Docker Compose)
#   - Rails API on port 3000  (hot-reloading)
#   - Dart Sass watcher
#   - Next.js portal on port 3001 (hot-reloading)

source "$(dirname "$0")/_lib.sh"

banner

# Start Postgres and block until its healthcheck passes.
echo "==> Starting Postgres..."
docker compose up postgres -d --wait

echo "==> Starting dev processes..."
exec overmind start -f "$ROOT_DIR/Procfile.dev"
