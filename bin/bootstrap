#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

STEPS_DIR="$SCRIPT_DIR/steps"

banner

CMD="${1:-}"

case "$CMD" in

  "")
    echo "This will run ALL bootstrap steps from the beginning."
    echo "Existing state will be ignored and steps re-executed."
    echo ""
    if prompt "Continue? [y/N]"; then
      run_steps "$STEPS_DIR"
    else
      info "Aborted."
    fi
    ;;

  run)
    run_steps "$STEPS_DIR"
    ;;

  list)
    list_steps "$STEPS_DIR"
    ;;

  graph)
    graph_steps "$STEPS_DIR"
    ;;

  doctor)

    echo ""
    echo "System Check"
    echo "============"

    check bun
    check git
    check docker
    check kamal
    check node
    check overmind
    check rails
    check ruby

    echo ""
    success "Environment looks good"
    ;;

  reset)
    info "Resetting bootstrap state"
    clear_state
    success "State cleared"
    ;;

  help|-h|--help)

    echo ""
    echo "Usage:"
    echo ""
    echo "  bin/bootstrap          Run bootstrap pipeline (prompts for confirmation)"
    echo "  bin/bootstrap run      Run bootstrap pipeline (no prompt)"
    echo "  bin/bootstrap list     List steps"
    echo "  bin/bootstrap graph    Show step graph"
    echo "  bin/bootstrap doctor   Check environment"
    echo "  bin/bootstrap reset    Reset pipeline state"
    echo "  bin/bootstrap 20       Run specific step"
    echo "  bin/bootstrap 10-20    Run steps 10 through 20 (inclusive)"
    echo "  bin/bootstrap 10+      Run steps from 10 to end"
    echo ""
    ;;

  *)
    if [[ "$CMD" =~ ^[0-9]{2}$ ]] || \
       [[ "$CMD" =~ ^[0-9]{2}-[0-9]{2}$ ]] || \
       [[ "$CMD" =~ ^[0-9]{2}\+$ ]]; then
      run_steps "$STEPS_DIR" "$CMD"
    else
      echo "Unknown command: $CMD"
      echo "Run: bin/bootstrap help"
      exit 1
    fi
    ;;

esac
