#!/usr/bin/env bash
# bin/kamal

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

API_CONFIG="$ROOT_DIR/config/deploy.api.yml"
PORTAL_CONFIG="$ROOT_DIR/config/deploy.portal.yml"

########################################
# Usage
########################################

usage() {
  echo ""
  echo "Usage:"
  echo ""
  echo "  bin/kamal <target> [kamal args]"
  echo ""
  echo "Targets:"
  echo "  api      EHR API"
  echo "  portal   EHR Portal"
  echo ""
  echo "Examples:"
  echo "  bin/kamal"
  echo "  bin/kamal api accessory exec postgres -i -- psql -U \$DB_USER -d ehr_api_production"
  echo "  bin/kamal api app exec --reuse -- bin/rails runner \"puts User.count\""
  echo "  bin/kamal api app exec -i --reuse -- bash"
  echo "  bin/kamal api app exec -i --reuse -- bin/rails console"
  echo "  bin/kamal api app logs -f"
  echo ""
}

########################################
# CLI
########################################

banner
require_command kamal

TARGET="${1:-}"

case "$TARGET" in

  api|portal)
    shift
    ;;

  help|-h|--help)
    usage
    exit 0
    ;;

  "")
    TARGET=$(select_menu "Select Target" "api" "portal")
    ;;

  *)
    fail "Unknown target: '$TARGET'. Run: bin/kamal help"
    ;;

esac

CONFIG="$([[ "$TARGET" == "api" ]] && echo "$API_CONFIG" || echo "$PORTAL_CONFIG")"

# Inject -c CONFIG before the -- separator (or at end if no -- present)
pre_sep=()
post_sep=()
found_sep=false
for arg in "$@"; do
  if [[ "$arg" == "--" && "$found_sep" == "false" ]]; then
    found_sep=true
    pre_sep+=("-c" "$CONFIG")
    post_sep+=("$arg")
  elif [[ "$found_sep" == "true" ]]; then
    post_sep+=("$arg")
  else
    pre_sep+=("$arg")
  fi
done
[[ "$found_sep" == "false" ]] && pre_sep+=("-c" "$CONFIG")

info "Running: kamal ${pre_sep[*]} ${post_sep[*]}"
kamal "${pre_sep[@]}" "${post_sep[@]}"
