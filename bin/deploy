#!/usr/bin/env bash
# bin/deploy

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

PORTAL_CONFIG="$ROOT_DIR/config/deploy.portal.yml"
API_CONFIG="$ROOT_DIR/config/deploy.api.yml"

########################################
# Deploy functions
########################################

deploy_api() {
  info "Deploying API"
  kamal deploy -c "$API_CONFIG"
}

deploy_portal() {
  info "Deploying Portal"
  kamal deploy -c "$PORTAL_CONFIG"
}

deploy_all() {
  deploy_portal
  deploy_api
}

deploy_rollback() {
  info "Rolling back last deployment"
  kamal rollback
}

rebuild_db() {
  info "Rebuilding database (API only)"
  info "This will:"
  echo "  1. Reset the database (destroy all data)"
  echo "  2. Re-run migrations and seeds"
  echo ""

  if ! prompt "Continue database rebuild? (y/N)"; then
    fail "Database rebuild cancelled"
  fi

  info "Running database reset..."
  # DISABLE_DATABASE_ENVIRONMENT_CHECK=1 allows db:reset on production-named environments (staging server)
  kamal app exec --reuse --roles web -c "$API_CONFIG" -- env DISABLE_DATABASE_ENVIRONMENT_CHECK=1 bin/rails db:reset

  success "Database rebuilt successfully"
}

purge_redis() {
  info "Purging Redis queue"
  info "This will:"
  echo "  1. Clear all pending jobs from the Sidekiq queue"
  echo "  2. Leave Redis cache intact"
  echo ""

  if ! prompt "Continue Redis purge? (y/N)"; then
    fail "Redis purge cancelled"
  fi

  info "Purging Redis queue..."
  # Use redis-cli FLUSHDB to clear just the database, not the entire server
  kamal app exec --reuse -c "$API_CONFIG" -- redis-cli FLUSHDB

  success "Redis queue purged successfully"
}

teardown_rebuild() {
  local service="${1:-all}"
  local config=""

  case "$service" in
    api)    config="$API_CONFIG" ;;
    portal) config="$PORTAL_CONFIG" ;;
    all)
      info "Tearing down and rebuilding entire deployment (API + Portal)"
      teardown_rebuild api
      teardown_rebuild portal
      return
      ;;
    *)
      fail "Unknown service: $service"
      ;;
  esac

  if [[ -z "$config" ]]; then
    fail "No config found for service: $service"
  fi

  info "Tearing down and rebuilding $service deployment..."
  warn "This will:"
  echo "  1. Stop all containers for $service"
  echo "  2. Destroy all volumes (DATABASE AND REDIS DATA WILL BE LOST)"
  echo "  3. Remove all images"
  echo "  4. Redeploy from scratch"
  echo ""

  if ! prompt "Continue teardown and rebuild for $service? (y/N)"; then
    fail "Teardown and rebuild cancelled"
  fi

  info "Tearing down $service..."
  # kamal remove may fail due to permission errors when cleaning up postgres data dir
  # (postgres user ownership), but the volume removal below handles cleanup properly.
  # Run with verbose output to show real-time progress. Permission errors are non-fatal.
  if kamal remove -c "$config"; then
    success "Containers and images removed"
  else
    # kamal remove may fail due to permission errors, but that's OK - we handle volume cleanup separately
    warn "Remove encountered errors (possibly permission-related, but continuing...)"
  fi

  info "Destroying volumes for $service..."
  # Extract service name from config to identify volumes
  local service_name
  if [[ "$config" == *"api"* ]]; then
    service_name="ehr-api"
  else
    service_name="ehr-portal"
  fi

  # Remove named volumes for this service (postgres and redis data)
  local volumes_removed=0
  if docker volume rm "${service_name}-postgres_data" 2>/dev/null; then
    volumes_removed=$((volumes_removed + 1))
  fi
  if docker volume rm "${service_name}-redis_data" 2>/dev/null; then
    volumes_removed=$((volumes_removed + 1))
  fi

  if [[ $volumes_removed -gt 0 ]]; then
    success "Removed $volumes_removed volume(s)"
  else
    info "No volumes found to remove"
  fi

  success "$service deployment fully cleaned"

  if prompt "Redeploy $service now? (y/N)"; then
    # For API, bring up accessories (Postgres, Redis) before the app
    if [[ "$service" == "api" ]]; then
      info "Starting Postgres accessory..."
      kamal accessory reboot postgres -c "$config" || true
      info "Starting Redis accessory..."
      kamal accessory reboot redis -c "$config" || true
      info "Waiting for accessories to be ready..."
      sleep 15  # Give Postgres/Redis time to start and be healthy
    fi

    case "$service" in
      api)    deploy_api ;;
      portal) deploy_portal ;;
    esac
  fi
}

########################################
# Preflight
########################################

preflight() {
  info "Running preflight checks..."

  require_command kamal
  require_command docker
  require_command git

  if ! docker info >/dev/null 2>&1; then
    fail "Docker does not appear to be running"
  fi

  if ! git diff --quiet || ! git diff --cached --quiet; then
    info "Git working tree is dirty"
    if ! prompt "Continue deploy anyway? (y/N)"; then
      fail "Deploy cancelled"
    fi
  fi

  success "Preflight checks passed"
}

########################################
# CLI
########################################

CMD="${1:-}"

case "$CMD" in

  api)
    preflight
    deploy_api
    ;;

  portal)
    preflight
    deploy_portal
    ;;

  all)
    preflight
    deploy_all
    ;;

  rollback)
    preflight
    deploy_rollback
    ;;

  rebuild-db)
    rebuild_db
    ;;

  purge-redis)
    purge_redis
    ;;

  teardown-rebuild)
    # Allow: bin/deploy teardown-rebuild [api|portal|all]
    teardown_rebuild "${2:-all}"
    ;;

  help|-h|--help)
    echo ""
    echo "Usage:"
    echo ""
    echo "  bin/deploy                    Interactive menu"
    echo "  bin/deploy api                Deploy API"
    echo "  bin/deploy portal             Deploy Portal"
    echo "  bin/deploy all                Deploy Portal + API"
    echo "  bin/deploy rollback           Rollback last deploy"
    echo "  bin/deploy rebuild-db         Rebuild database (db:reset on API)"
    echo "  bin/deploy purge-redis        Purge Redis queue (clear Sidekiq jobs)"
    echo "  bin/deploy teardown-rebuild   Full teardown and rebuild (prompts for confirmation)"
    echo "  bin/deploy teardown-rebuild [api|portal|all]  Teardown and rebuild specific service"
    echo ""
    ;;

  "")
    preflight

    selection=$(select_menu "Deploy Target" \
      "api" \
      "portal" \
      "all" \
      "rollback" \
      "rebuild-db" \
      "purge-redis" \
      "teardown-rebuild")

    case "$selection" in
      api)              deploy_api ;;
      portal)           deploy_portal ;;
      all)              deploy_all ;;
      rollback)         deploy_rollback ;;
      rebuild-db)       rebuild_db ;;
      purge-redis)      purge_redis ;;
      teardown-rebuild) teardown_rebuild "all" ;;
      *)                fail "Invalid option: $selection" ;;
    esac
    ;;

  *)
    echo "Unknown command: $CMD"
    echo "Run: bin/deploy help"
    exit 1
    ;;

esac
