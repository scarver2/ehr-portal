#!/usr/bin/env bash
# bin/deploy

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

PORTAL_CONFIG="$ROOT_DIR/config/deploy.portal.yml"
API_CONFIG="$ROOT_DIR/config/deploy.api.yml"

########################################
# Deploy functions
########################################

deploy_api() {
  info "Deploying API"
  kamal deploy -c "$API_CONFIG"
}

deploy_portal() {
  info "Deploying Portal"
  kamal deploy -c "$PORTAL_CONFIG"
}

deploy_all() {
  deploy_portal
  deploy_api
}

deploy_rollback() {
  info "Rolling back last deployment"
  kamal rollback
}

########################################
# Preflight
########################################

preflight() {
  info "Running preflight checks..."

  require_command kamal
  require_command docker
  require_command git

  if ! docker info >/dev/null 2>&1; then
    fail "Docker does not appear to be running"
  fi

  if ! git diff --quiet || ! git diff --cached --quiet; then
    info "Git working tree is dirty"
    if ! prompt "Continue deploy anyway? (y/N)"; then
      fail "Deploy cancelled"
    fi
  fi

  success "Preflight checks passed"
}

########################################
# CLI
########################################

CMD="${1:-}"

case "$CMD" in

  api)
    preflight
    deploy_api
    ;;

  portal)
    preflight
    deploy_portal
    ;;

  all)
    preflight
    deploy_all
    ;;

  rollback)
    preflight
    deploy_rollback
    ;;

  help|-h|--help)
    echo ""
    echo "Usage:"
    echo ""
    echo "  bin/deploy             Interactive menu"
    echo "  bin/deploy api         Deploy API"
    echo "  bin/deploy portal      Deploy Portal"
    echo "  bin/deploy all         Deploy Portal + API"
    echo "  bin/deploy rollback    Rollback last deploy"
    echo ""
    ;;

  "")
    preflight

    selection=$(select_menu "Deploy Target" \
      "api" \
      "portal" \
      "all" \
      "rollback")

    case "$selection" in
      api)      deploy_api ;;
      portal)   deploy_portal ;;
      all)      deploy_all ;;
      rollback) deploy_rollback ;;
      *)        fail "Invalid option: $selection" ;;
    esac
    ;;

  *)
    echo "Unknown command: $CMD"
    echo "Run: bin/deploy help"
    exit 1
    ;;

esac
