#!/usr/bin/env bash
# bin/deploy

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

PORTAL_CONFIG="$ROOT_DIR/config/deploy.portal.yml"
API_CONFIG="$ROOT_DIR/config/deploy.api.yml"

########################################
# Deploy functions
########################################

deploy_api() {
  info "Deploying API"
  kamal deploy -c "$API_CONFIG"
}

deploy_portal() {
  info "Deploying Portal"
  kamal deploy -c "$PORTAL_CONFIG"
}

deploy_all() {
  deploy_portal
  deploy_api
}

deploy_rollback() {
  info "Rolling back last deployment"
  kamal rollback
}

reset_deployment() {
  local service="${1:-all}"
  local config=""

  case "$service" in
    api)    config="$API_CONFIG" ;;
    portal) config="$PORTAL_CONFIG" ;;
    all)
      info "Resetting entire deployment (API + Portal)"
      reset_deployment api
      reset_deployment portal
      return
      ;;
    *)
      fail "Unknown service: $service"
      ;;
  esac

  if [[ -z "$config" ]]; then
    fail "No config found for service: $service"
  fi

  info "Resetting $service deployment..."
  warn "This will:"
  echo "  1. Stop all containers for $service"
  echo "  2. Remove all volumes (DATABASE AND REDIS DATA WILL BE LOST)"
  echo "  3. Remove all images"
  echo "  4. Redeploy from scratch"
  echo ""

  if ! prompt "Continue reset for $service? (y/N)"; then
    fail "Reset cancelled"
  fi

  info "Tearing down $service..."
  kamal remove -c "$config" || true

  info "Removing volumes for $service..."
  # Extract service name from config to identify volumes
  local service_name
  if [[ "$config" == *"api"* ]]; then
    service_name="ehr-api"
  else
    service_name="ehr-portal"
  fi

  # Remove named volumes for this service (postgres and redis data)
  docker volume rm "${service_name}-postgres_data" 2>/dev/null || true
  docker volume rm "${service_name}-redis_data" 2>/dev/null || true

  success "$service deployment removed"

  if prompt "Redeploy $service now? (y/N)"; then
    # For API, we need to bring up accessories (Postgres, Redis) before the app
    if [[ "$service" == "api" ]]; then
      info "Starting accessories (Postgres, Redis)..."
      kamal accessory boot postgres -c "$config" || true
      kamal accessory boot redis -c "$config" || true
      info "Waiting for accessories to be ready..."
      sleep 10  # Give Postgres/Redis time to start
    fi

    case "$service" in
      api)    deploy_api ;;
      portal) deploy_portal ;;
    esac
  fi
}

########################################
# Preflight
########################################

preflight() {
  info "Running preflight checks..."

  require_command kamal
  require_command docker
  require_command git

  if ! docker info >/dev/null 2>&1; then
    fail "Docker does not appear to be running"
  fi

  if ! git diff --quiet || ! git diff --cached --quiet; then
    info "Git working tree is dirty"
    if ! prompt "Continue deploy anyway? (y/N)"; then
      fail "Deploy cancelled"
    fi
  fi

  success "Preflight checks passed"
}

########################################
# CLI
########################################

CMD="${1:-}"

case "$CMD" in

  api)
    preflight
    deploy_api
    ;;

  portal)
    preflight
    deploy_portal
    ;;

  all)
    preflight
    deploy_all
    ;;

  rollback)
    preflight
    deploy_rollback
    ;;

  reset)
    # Allow: bin/deploy reset [api|portal|all]
    reset_deployment "${2:-all}"
    ;;

  help|-h|--help)
    echo ""
    echo "Usage:"
    echo ""
    echo "  bin/deploy             Interactive menu"
    echo "  bin/deploy api         Deploy API"
    echo "  bin/deploy portal      Deploy Portal"
    echo "  bin/deploy all         Deploy Portal + API"
    echo "  bin/deploy rollback    Rollback last deploy"
    echo "  bin/deploy reset       Teardown and rebuild (prompts for confirmation)"
    echo "  bin/deploy reset [api|portal|all]  Reset specific service"
    echo ""
    ;;

  "")
    preflight

    selection=$(select_menu "Deploy Target" \
      "api" \
      "portal" \
      "all" \
      "rollback" \
      "reset")

    case "$selection" in
      api)      deploy_api ;;
      portal)   deploy_portal ;;
      all)      deploy_all ;;
      rollback) deploy_rollback ;;
      reset)    reset_deployment "all" ;;
      *)        fail "Invalid option: $selection" ;;
    esac
    ;;

  *)
    echo "Unknown command: $CMD"
    echo "Run: bin/deploy help"
    exit 1
    ;;

esac
