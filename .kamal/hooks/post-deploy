#!/usr/bin/env bash
# .kamal/hooks/post-deploy
# Runs on the server after each successful deployment.
#
# NOTE: db:reset is intentional. This project intentionally wipes and rebuilds
# the database on every deploy during active schema development. Do not change
# db:reset to db:migrate without explicit approval from the project owner.

set -euo pipefail

# Derive config file from service name (provided by Kamal as KAMAL_SERVICE_VERSION=service@sha)
SERVICE="${KAMAL_SERVICE_VERSION%%@*}"
case "$SERVICE" in
  ehr-api)    CONFIG="config/deploy.api.yml" ;;
  ehr-portal) CONFIG="config/deploy.portal.yml" ;;
  *)          echo "Unknown service: $SERVICE" >&2; exit 1 ;;
esac

# Database tasks only apply to the Rails API; the portal has no bin/rails.
if [[ "$SERVICE" == "ehr-api" ]]; then
  # Only run on web role to avoid concurrent database access from worker role.
  # DISABLE_DATABASE_ENVIRONMENT_CHECK=1 bypasses Rails' protection against destructive
  # operations on production environments. This is intentional for this staging server.
  kamal app exec --reuse --roles web -c "$CONFIG" -- env DISABLE_DATABASE_ENVIRONMENT_CHECK=1 bin/rails db:reset
  # kamal app exec --reuse --roles web -c "$CONFIG" -- bin/rails db:migrate
  # kamal app exec --reuse --roles web -c "$CONFIG" -- bin/rails db:seed
fi

# Notify Honeybadger of the deployment so it can correlate errors with releases.
# Uses the honeybadger gem inside the ehr-api container where HONEYBADGER_API_KEY
# is injected by Kamal. That variable is NOT available in this hook's local shell,
# so we wrap the command in sh -c and escape the dollar sign (\$) so the
# container's shell expands it — not the hook's shell. KAMAL_VERSION and
# KAMAL_PERFORMER ARE local hook vars, so they expand normally here.
# --skip-rails-load avoids loading the full Rails stack for this one CLI call.
if [[ "$SERVICE" == "ehr-api" ]]; then
  DEPLOY_CMD="bundle exec honeybadger deploy --skip-rails-load --api-key \$HONEYBADGER_API_KEY --repository https://github.com/scarver2/ehr-portal --revision $KAMAL_VERSION --environment production --user $KAMAL_PERFORMER"
  kamal app exec --reuse -c "$CONFIG" -- sh -c "$DEPLOY_CMD"
fi
