#!/usr/bin/env bash
# apps/ehr-portal/bin/lint
#
# Usage:
#   bin/lint                        # default lint report
#   bin/lint --fix                  # apply auto-fixes

source "$(dirname "$0")/_lib.sh"

# Support both npm and bun
if command -v bun &>/dev/null; then
  bun run --silent lint "$@"
elif command -v npm &>/dev/null; then
  npm run --silent lint "$@"
else
  require_command npm
fi
