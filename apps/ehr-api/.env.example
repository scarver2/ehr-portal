# apps/ehr-api/.env.example — copy to .env and fill in values
# .env is gitignored; this file is committed as a reference template.

# == Database connection
# Defaults: localhost:5432, user=postgres, no password
# Only set these if your local setup differs.
# For CI/production, these are set via environment secrets.
#
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=

# https://www.honeybadger.io — error monitoring
# HONEYBADGER_API_KEY=

# Redis — configure for development
# Sidekiq uses database 0, ActionCable uses database 1 (configured in config/cable.yml).
# Default: Homebrew Redis on localhost. In production, passed via Kamal secrets.
# REDIS_URL=redis://localhost:6379/0

# GitHub
# used to identify build
# GITHUB_USER=
# GITHUB_TOKEN=
