# apps/ehr-api/.env.example — copy to .env and fill in values
# .env is gitignored; this file is committed as a reference template.

# == Database connection
# Defaults match Homebrew Postgres (port 5432).
# Set DB_PORT=5433 when using Docker Compose (compose.yml maps host 5433 → container 5432).
#
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres

# https://www.honeybadger.io — error monitoring
# HONEYBADGER_API_KEY=

# Redis — configure for development
# Sidekiq uses database 0 (default fallback: localhost:6379/0)
# REDIS_URL=redis://localhost:6379/0
#
# ActionCable uses database 1 (separate for isolation, default fallback: localhost:6379/1)
# ACTIONCABLE_REDIS_URL=redis://localhost:6379/1
#
# In production via Kamal, only REDIS_URL is used (passed via secrets).

# GitHub
# used to identify build
# GITHUB_USER=
# GITHUB_TOKEN=
