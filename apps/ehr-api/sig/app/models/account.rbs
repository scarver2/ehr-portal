class Account < ApplicationRecord
  JWT_ALGORITHM: String
  JWT_TTL: ActiveSupport::Duration
  JWT_ISSUER: String

  attr_reader id: Integer
  attr_accessor user_id: Integer
  attr_accessor email: String
  attr_accessor password_hash: String
  attr_accessor status: String
  attr_accessor last_login_at: Time?
  attr_accessor last_login_ip: String?
  attr_accessor failed_login_attempts: Integer?
  attr_reader created_at: Time
  attr_reader updated_at: Time

  # Association
  def user: () -> User

  # Password validation
  def valid_password?: (String password) -> bool

  # JWT token generation
  def generate_jwt_token: () -> String

  # JWT token verification
  def self.verify_jwt_token: (String? token) -> Hash[String, untyped]?

  # Find user from JWT token
  def self.find_user_from_jwt: (String? token) -> User?
end
