# sig/app/models/user.rbs
# Rodauth JWT Authentication + Rolify Role Management
# Portal users authenticate via JWT tokens (stateless)
# Roles managed via Rolify (dynamic role assignment)

class User < ApplicationRecord
  attr_reader id: Integer
  attr_accessor email: String
  attr_reader created_at: Time
  attr_reader updated_at: Time

  # Associations
  def account: () -> Account?
  def patient: () -> Patient?
  def provider: () -> Provider?
  def insurance_profile: () -> InsuranceProfile?
  def insurance_verifications: () -> ::ActiveRecord::Associations::CollectionProxy
  def roles: () -> ::ActiveRecord::Associations::CollectionProxy

  # Rolify methods
  def add_role: (String | Symbol role) -> void
  def has_role?: (String | Symbol role) -> bool
  def remove_role: (String | Symbol role) -> void

  # Validation
  def has_at_least_one_role: () -> void

  # Scope for provider accounts
  def self.provider_accounts: () -> ::ActiveRecord::Relation
end
